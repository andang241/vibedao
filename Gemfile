source "https://rubygems.org"

# Bộ gem "github-pages" mô phỏng CHÍNH XÁC môi trường build của GitHub Pages.
# Dùng nó để chạy local giống hệt lúc deploy, tránh lỗi "chạy máy mình OK
# nhưng lên GitHub lại hỏng".
gem "github-pages", group: :jekyll_plugins

# Cần cho một số hệ điều hành khi xử lý dữ liệu múi giờ.
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]

# Tăng tốc rebuild khi xem preview local (tùy chọn).
gem "webrick", "~> 1.7"
